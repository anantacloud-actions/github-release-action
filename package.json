{
  "name": "github-release-action",
  "version": "1.0.0",
  "description": "GitHub Action to create releases",
  "main": "src/index.js",
  "scripts": {
    "build": "ncc build index.js -o dist",
    "watch": "ncc build index.js -o dist --watch",
    "start": "node dist/index.js",
    "dev": "node index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "echo \"No tests yet\" && exit 0",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
